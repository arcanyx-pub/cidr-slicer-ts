{
    "name": "@arcanyx/cidr-slicer",
    "version": "0.3.0",
    "description": "Lib for partitioning IPv4 and IPv6 CIDR blocks into smaller slices.",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
        "build": "npm run clean && tsc --project tsconfig.build.json",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "lint": "biome check",
        "format": "biome check --write"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/arcanyx-pub/cidr-slicer-ts.git"
    },
    "homepage": "https://github.com/arcanyx-pub/cidr-slicer-ts",
    "keywords": [
        "cidr",
        "ipv6",
        "subnets"
    ],
    "author": "Joe Dahlquist <joe@arcanyx.com>",
    "license": "MIT",
    "devDependencies": {
        "@arcanyx/biome-config": "^0.1.2",
        "@biomejs/biome": "^2.5.3",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    }
}
